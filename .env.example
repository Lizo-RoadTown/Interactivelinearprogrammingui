# Frontend environment template.
# Copy to .env.local and fill in real values for local dev.
# In production (Render / Vercel), set these as build-time env vars.

# Supabase — drives auth + direct DB reads from the browser.
# Both values are safe in browser code: the anon key is designed for
# client use, and Row-Level Security policies in Postgres are what
# actually gate access.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: backend base URL (FastAPI) for endpoints that can't move
# to direct-Supabase, like the BYO-agent draft endpoint that proxies
# Anthropic / OpenAI keys without persisting them.
# In dev this defaults to http://localhost:8000.
# In prod, set to the Render service URL.
VITE_API_URL=
